      <site site="hip_right_hook_back"/>
    </spatial> -->

  </tendon>

  <sensor>
    <!-- <tendonforce name="hip_left_tension" tendon="hip_left_tendon_back"/> -->
    <!-- <tendonforce name="hip_right_tension" tendon="hip_right_tendon_back"/> -->
