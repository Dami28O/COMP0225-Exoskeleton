    </spatial>

    <spatial name="hip_left_tendon_top" class="Hip_harness_tendon">
      <site site="leg_top_in_L"/>

      <!-- <site site="hip_right_hook_back"/>
      <site site="hip_right_hook_back_2"/>
      <site site="hip_right_hook_back_3"/>
      <site site="hip_right_hook_back_4"/>
      <site site="hip_right_hook_back_5"/>
      <site site="hip_right_hook_back_6"/> -->

      <!-- <site site="hip_right_hook_back_top"/> -->
      <site site="hip_left_hook_back_top_2"/>
      <site site="hip_left_hook_back_top_3"/>
      <site site="hip_left_hook_back_top_4"/>
      <site site="hip_left_hook_back_top_5"/>
