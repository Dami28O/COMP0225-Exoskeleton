<mujoco model="hipexo v2 with human v2">
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- Multiple Robots with Torque-Controlled Exoskeleton  -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->

  <!-- Include Common Scene -->
  <include file="common_scene.xml"/>

  <!-- Include Human -->
  <include file="human_v2.xml"/>

  <!-- Include Torque-Controlled Exoskeleton -->
  <include file="hipexo_v2_real_inertia.xml"/>  

  <default>
    <!-- Harness Tendon Classes -->
    <default class="Shoulder_harness_tendon">
      <tendon limited="true" range="0 .6" width="0.01" rgba="0.2 0.4 0.4 1"/>
    </default>

    <default class="pelvis_harness_tendon">
      <tendon limited="true" range="0 .8" width="0.01" rgba="0.2 0.4 0.4 1"/>
    </default>

    <default class="Hip_harness_tendon">
      <!-- High stiffness for near-inelastic tendon (rigid torque transmission) -->
      <tendon limited="true" range="0 .3" width="0.01" rgba="0.2 0.4 0.4 1"/>
              <!-- stiffness="100000" damping="100" rgba="1 0 0 1"/> -->
    </default>

    <default class="flexible_tendon">
      <tendon limited="true" range="0 .005" width="0.001"
              stiffness="5000" damping="5" rgba="0 1 0 1"/>
    </default>
  </default>

   <!-- Tendons -->
  <tendon>
    <!-- Shoulder Harness Tendons -->
    <spatial name="shoulder_left_tendon" class="Shoulder_harness_tendon">
      <site site="backframe_to_shoulder_top_L"/>
      
      <site site="shoulder_left_hook"/>
      <site site="shoulder_left_hook_2"/>
      <site site="shoulder_left_hook_3"/>
      <site site="shoulder_left_hook_4"/>
      <site site="shoulder_left_hook_5"/>

      <site site="backframe_to_shoulder_bottom_L"/>
    </spatial>

    <spatial name="shoulder_right_tendon" class="Shoulder_harness_tendon">
      <site site="backframe_to_shoulder_top_R"/>
      
      <site site="shoulder_right_hook"/>
      <site site="shoulder_right_hook_2"/>
      <site site="shoulder_right_hook_3"/>
      <site site="shoulder_right_hook_4"/>
      <site site="shoulder_right_hook_5"/>

      <site site="backframe_to_shoulder_bottom_R"/>
    </spatial>

    <!-- <spatial name="shoulder_left_tendon_back" class="Shoulder_harness_tendon_top">
      <site site="backframe_to_shoulder_top_L"/>
      <site site="shoulder_left_hook_top"/>
    </spatial>
    <spatial name="shoulder_left_tendon_side" class="Shoulder_harness_tendon_bottom">
      <site site="backframe_to_shoulder_bottom_L"/>
      <site site="shoulder_left_hook_bottom"/>
    </spatial>
    <spatial name="shoulder_right_tendon_back" class="Shoulder_harness_tendon_top">
      <site site="backframe_to_shoulder_top_R"/>
      <site site="shoulder_right_hook_top"/>
    </spatial>
    <spatial name="shoulder_right_tendon_side" class="Shoulder_harness_tendon_bottom">
      <site site="backframe_to_shoulder_bottom_R"/>
      <site site="shoulder_right_hook_bottom"/>
    </spatial> -->
    
    <!-- pelvis Harness Tendons -->
    
    <!-- <spatial name="pelvis_left_tendon_top" class="pelvis_harness_tendon">
      <site site="hip_L_to_pelvis_L_top"/>
      <site site="pelvis_left_hook_top"/>
      <site site="pelvis_right_hook_top"/>
      <site site="hip_R_to_pelvis_R_top"/>
    </spatial>

    <spatial name="pelvis_left_tendon_bottom" class="pelvis_harness_tendon">
      <site site="hip_L_to_pelvis_L_bottom"/>
      <site site="pelvis_left_hook_bottom"/>
      <site site="pelvis_right_hook_bottom"/>
      <site site="hip_R_to_pelvis_R_bottom"/>
    </spatial> -->

    <spatial name="pelvis_strap" class="pelvis_harness_tendon">
      <site site="hip_L_to_pelvis_L_top"/>
      <site site="pelvis_left_hook_top"/>
      <site site="pelvis_right_hook_top"/>
      <site site="hip_R_to_pelvis_R_top"/>
      <site site="hip_R_to_pelvis_R_bottom"/>
      <site site="pelvis_right_hook_bottom"/>
      <site site="pelvis_right_hook_bottom_2"/>
      <site site="pelvis_right_hook_bottom_3"/>
      <site site="pelvis_left_hook_bottom_3"/>
      <site site="pelvis_left_hook_bottom_2"/>
      <site site="pelvis_left_hook_bottom"/>
      <site site="hip_L_to_pelvis_L_bottom"/>
      <site site="hip_L_to_pelvis_L_top"/>
    </spatial>
