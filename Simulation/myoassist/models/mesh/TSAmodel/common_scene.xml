<mujoco model="Common Scene">
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <!-- Common Scene: 조명, 바닥, 배경 등 공통 환경         -->
  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->

  <!-- Simulation Options: implicitfast for stability with stiff joints -->
  <option integrator="implicitfast">
    <flag energy="enable"/>
  </option>

  <!-- Visual Settings -->
  <visual>
    <!-- Free camera 초기 설정: 인체 모델 관찰에 적합한 거리/각도 -->
    <global offwidth="1280" offheight="960" azimuth="135" elevation="-20"/>
    <headlight active="1" ambient="0.34 0.34 0.34" diffuse="0.5 0.5 0.5"/>
    <scale framelength="0.5" framewidth="0.01"/>
  </visual>

  <!-- Free camera가 CoM을 추적하도록 statistic 설정 -->
  <statistic center="0 0 1" extent="2"/>

  <!-- Assets: Textures and Materials -->
  <asset>
    <!-- Sky -->
    <texture type="skybox" builtin="gradient"
             rgb1="0.99 0.99 0.99" rgb2="0.608 0.828 0.892"
             width="10" height="10"/>

    <!-- Floor -->
    <texture name="texplane" type="2d" builtin="checker"
             markrgb="1 1 1" rgb1="0.756 0.772 0.76" rgb2="0.6 0.6 0.6"
             width="10" height="10"/>

    <material name="MatPlane"
              reflectance="0.5"
              texture="texplane"
              texrepeat="1 1"
              texuniform="true"/>

    <!-- Geom texture (optional) -->
    <texture builtin="flat" height="1278" mark="cross" markrgb="1 1 1"
             name="texgeom" random="0.01"
             rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4"
             type="cube" width="127"/>
    <material name="geom" texture="texgeom" texuniform="true"/>
  </asset>

  <!-- World Body: Lights, Floor, Camera -->
  <worldbody>
    <!-- Tracking Light: follows center of mass -->
    <light name="tracking_light" pos="0 0 7" dir="0 0 -1"
           directional="true" cutoff="100" exponent="1"
           diffuse="1 1 1" specular="0.1 0.1 0.1"
           mode="trackcom"/>

    <!-- Floor: 3D contact for stability -->
    <geom condim="3" name="floor" pos="0 0 0"
          rgba="1 1 1 1" size="100 100 .2"
          type="plane" material="MatPlane"/>

    <!-- Tracking Cameras: follow center of mass -->
    <camera name="back" pos="0 2 1.2" xyaxes="-1 0 0 0 -0.5 1" mode="trackcom"/>
    <camera name="side" pos="-2 0 1.2" xyaxes="0 -1 0 0.25 0 1" mode="trackcom"/>
    <camera name="front_side" pos="-1.5 -1.5 1.2" xyaxes="0.7 -0.7 0 0.2 0.2 1" mode="trackcom"/>
  </worldbody>

</mujoco>
