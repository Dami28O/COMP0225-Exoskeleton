                    </body>

                    <!-- Hip support -->
                    <body name="hip_support_L" pos="0.019 0 0" euler="0 0 0">
                        <joint name="hip_support_joint_L" type="hinge" axis="1 0 0" pos="0 0 0"
                               class="exo/passive_joint" range="-0.5 0.5"/>
                        <geom name="hip_support_L_geom" type="mesh" mesh="hip_support"
                              class="exo/collision" material="mat_hip_support"/>
                        <!-- hip_support (L): from real_inertia.txt (at CoM) -->
                        <inertial mass="0.01250169" pos="0.00570428 -0.00749738 0"
                                  fullinertia="0.00000658 0.00000607 0.00000078 -0.00000012 0 0"/>

                        <!-- Sites for hip_L strap -->
                        <site name="hip_L_to_pelvis_L_top" pos="0.008 -0.016 0.025"/>
                        <site name="hip_L_to_pelvis_L_bottom" pos="0.008 -0.016 -0.025"/>
                    </body>

                    <!-- TSA motor pipe & connector -->
                    <body name="tsa_motor_pipe_L" pos="0 -0.170 0.441" euler="0.235 0 0">
                        <geom name="tsa_motor_pipe_L_geom" type="mesh" mesh="tsa_motor_pipe"
                              class="exo/collision" material="mat_joint"/>
                        <!-- tsa_motor_pipe (L): from real_inertia.txt (at CoM) -->
                        <inertial mass="0.68795278" pos="0.00008014 -0.00000370 0.04838748"
                                  fullinertia="0.00372618 0.00373338 0.00014605 0 -0.00000075 0.00000005"/>

                        <body name="connector_L" pos="0.0624 0 0.0713" euler="0 0.914 1.5708">
                            <joint name="connector_joint_L" type="hinge" axis="-1 0 0" pos="-0.005 0 -0.034"
                                   class="exo/passive_joint" range="-0.8 0.8"/>
                            <geom name="connector_L_geom" type="mesh" mesh="connector"
                                  class="exo/visual" material="mat_connector"/>
                            <!-- connector (L): from real_inertia.txt (at CoM) -->
                            <inertial mass="0.00278131" pos="0 0 -0.02005725"
                                      fullinertia="0.00000038 0.00000042 0.00000007 0 0 0"/>

                            <!-- Site for closed loop constraint -->
                            <site name="connector_L_to_backframe" pos="0 0 0"/>
                        </body>
                    </body>
                </body>
            </body>

            <!-- ==================== RIGHT SIDE ==================== -->
            <body name="backpipe_half_R" pos="0.16 0.183 0.035" euler="0.16 0 0">
                <joint name="backpipe_joint_R" type="hinge" axis="1 0 0" pos="-0.15 -0.22 0"
                       class="exo/structural_joint" range="-0.3 0.3"/>
                <geom name="backpipe_half_R_geom" type="mesh" mesh="backpipe_half" euler="0 3.14159 0"
                      class="exo/visual" material="mat_backpipe"/>
                <!-- backpipe_half (R): from real_inertia.txt (at CoM), X-mirrored -->
                <inertial mass="0.05548025" pos="-0.03328886 -0.14909289 0"
                          fullinertia="0.00029720 0.00012446 0.00041663 0.00012871 0 0"/>

                <body name="joint_base_R" pos="0.034 0 -0.098" euler="0 -0.119 0">
                    <joint name="pipe_joint_R" type="hinge" axis="0 -1 0" pos="-0.0225 -0.022 0.101"
                           class="exo/structural_joint" range="-0.5 0.5"/>
                    <geom name="joint_base_R_geom" type="mesh" mesh="joint_base_R"
                          class="exo/collision" material="mat_joint"/>
                    <!-- joint_base_R: from real_inertia.txt (at CoM) -->
                    <inertial mass="0.32399464" pos="-0.00261229 -0.02913265 0.02882577"
                              fullinertia="0.00088962 0.00049097 0.00043955 -0.00000556 -0.00002313 -0.00024432"/>

                    <!-- Pulley & Leg -->
                    <body name="pulley_R" pos="0 0 0" euler="0 0 0">
                        <joint name="hip_joint_R" type="hinge" axis="1 0 0" pos="0 0 0"
                               class="exo/active_joint" range="-0.3 2.2"/>
                        <geom name="pulley_R_geom" type="mesh" mesh="pulley_R"
                              class="exo/collision" material="mat_pulley"/>
                        <!-- pulley_R: from real_inertia.txt (at CoM) -->
                        <inertial mass="0.09716543" pos="0.00012873 -0.01038358 -0.02273681"
                                  fullinertia="0.00023246 0.00017091 0.00007127 0.00000036 0.00000022 -0.00001507"/>

                        <body name="leg_R" pos="0 0 -0.0665" euler="0 0 0">
                            <joint name="leg_joint_R" type="hinge" axis="0 1 0" pos="0 0 0"
                                   class="exo/active_joint" range="-1.57 0.3"/>
                            <geom name="leg_R_geom" type="mesh" mesh="leg_R"
                                  class="exo/visual" material="mat_leg"/>
                            <!-- leg_R: from real_inertia.txt (at CoM) -->
                            <inertial mass="0.40720231" pos="-0.01271929 -0.07381513 -0.07182694"
                                      fullinertia="0.00185796 0.00149450 0.00091057 0.00017231 0.00021842 0.00058454"/>

                            <geom name="leg_in_R_contact" class="exo/collision" type="cylinder" size="0.005 0.04" pos="-0.103 -0.104 -0.115"/>
                            <geom name="leg_out_R_contact" class="exo/collision" type="cylinder" size="0.005 0.04" pos="-0.002 -0.045 -0.115"/>

                            <!-- Sites for leg_R strap -->
                            <!-- <site name="leg_R_in_to_thigh_R_in" pos="-0.1 -0.1 -0.11"/> -->
                            <!-- <site name="leg_R_out_to_thigh_R_out" pos="-0.01 -0.05 -0.11"/> -->

                            <site name="leg_top_in_R" pos="-0.1 -0.095 -0.09"/>
                            <site name="leg_top_out_R" pos="-0.02 -0.05 -0.09"/>
                            <site name="leg_bottom_in_R" pos="-0.1 -0.095 -0.13"/>
                            <site name="leg_bottom_out_R" pos="-0.02 -0.05 -0.13"/>
                            <!-- <site name="leg_R_out_to_thigh_R_out" pos="-0.01 -0.05 -0.11"/> -->
                        </body>
                    </body>

                    <!-- Hip support -->
                    <body name="hip_support_R" pos="-0.019 0 0" euler="0 0 0">
                        <joint name="hip_support_joint_R" type="hinge" axis="-1 0 0" pos="0 0 0"
                               class="exo/passive_joint" range="-0.5 0.5"/>
                        <geom name="hip_support_R_geom" type="mesh" mesh="hip_support" euler="0 3.14159 0"
                              class="exo/collision" material="mat_hip_support"/>
                        <!-- hip_support (R): from real_inertia.txt (at CoM), X-mirrored -->
                        <inertial mass="0.01250169" pos="-0.00570428 -0.00749738 0"
                                  fullinertia="0.00000658 0.00000607 0.00000078 0.00000012 0 0"/>

                        <!-- Sites for hip_R strap -->
                        <site name="hip_R_to_pelvis_R_top" pos="-0.008 -0.016 0.025"/>
                        <site name="hip_R_to_pelvis_R_bottom" pos="-0.008 -0.016 -0.025"/>
                    </body>

                    <!-- TSA motor pipe & connector -->
                    <body name="tsa_motor_pipe_R" pos="0 -0.170 0.441" euler="0.235 0 3.14159">
                        <geom name="tsa_motor_pipe_R_geom" type="mesh" mesh="tsa_motor_pipe"
                              class="exo/collision" material="mat_joint"/>
                        <!-- tsa_motor_pipe (R): from real_inertia.txt (at CoM), X-mirrored -->
                        <inertial mass="0.68795278" pos="-0.00008014 0.00000370 0.04838748"
                                  fullinertia="0.00372618 0.00373338 0.00014605 0 0.00000075 -0.00000005"/>

                        <body name="connector_R" pos="0.0624 0 0.0713" euler="0 0.914 1.5708">
                            <joint name="connector_joint_R" type="hinge" axis="-1 0 0" pos="-0.005 0 -0.034"
                                   class="exo/passive_joint" range="-0.8 0.8"/>
                            <geom name="connector_R_geom" type="mesh" mesh="connector"
                                  class="exo/visual" material="mat_connector"/>
                            <!-- connector (R): from real_inertia.txt (at CoM) - symmetric -->
                            <inertial mass="0.00278131" pos="0 0 -0.02005725"
                                      fullinertia="0.00000038 0.00000042 0.00000007 0 0 0"/>

                            <!-- Site for closed loop constraint -->
                            <site name="connector_R_to_backframe" pos="0 0 0"/>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <!-- ==================== EQUALITY CONSTRAINT PARAMETERS ==================== -->
    <!--
        MuJoCo doesn't support default classes for equality constraints.
        Common parameters defined here for easy bulk modification:

        CONSTRAINT PRESETS (copy-paste to all constraints):
        ┌─────────────┬─────────────────┬───────────────────────────┐
        │ Preset      │ solref          │ solimp                    │
        ├─────────────┼─────────────────┼───────────────────────────┤
        │ Stiff       │ "0.002 1"       │ "0.99 0.999 0.0001"       │ ← Current
        │ Medium      │ "0.005 1"       │ "0.95 0.99 0.001"         │
        │ Soft        │ "0.01 1"        │ "0.9 0.99 0.005"          │
        │ Very Stiff  │ "0.001 1"       │ "0.995 0.9999 0.00001"    │
        └─────────────┴─────────────────┴───────────────────────────┘

        Parameters explained:
        - solref: [timeconst, dampratio] - constraint stiffness/damping
        - solimp: [dmin, dmax, width] - constraint tolerance bounds
    -->

    <equality>
        <!-- Closed loop: backframe ↔ connector ball joints -->
        <connect name="connector_ball_L"
                 site1="backframe_to_connector_L"
                 site2="connector_L_to_backframe"
                 solref="0.002 1"
                 solimp="0.9 0.9 0.0001"/>

        <connect name="connector_ball_R"
                 site1="backframe_to_connector_R"
                 site2="connector_R_to_backframe"
                 solref="0.002 1"
                 solimp="0.9 0.9 0.0001"/>
    </equality>

    <!-- ==================== ACTUATORS ==================== -->
    <actuator>
        <!-- Hip joint motors (main actuation) -->
        <motor name="left_hip_servo" joint="hip_joint_L" gear="50"
               ctrllimited="true" ctrlrange="-1 1"/>
        <motor name="right_hip_servo" joint="hip_joint_R" gear="-50"
               ctrllimited="true" ctrlrange="-1 1"/>
    </actuator>

    <!-- ==================== SENSORS ==================== -->
    <sensor>
        <!-- Joint position sensors -->
        <jointpos name="hip_L_pos" joint="hip_joint_L"/>
        <jointpos name="hip_R_pos" joint="hip_joint_R"/>

        <!-- Joint velocity sensors -->
        <jointvel name="hip_L_vel" joint="hip_joint_L"/>
        <jointvel name="hip_R_vel" joint="hip_joint_R"/>

        <!-- Actuator force sensors -->
        <actuatorfrc name="hip_L_frc" actuator="left_hip_servo"/>
        <actuatorfrc name="hip_R_frc" actuator="right_hip_servo"/>
    </sensor>

    <!-- ==================== CONTACT EXCLUSIONS ==================== -->
    <contact>
        <!-- Exclude self-collision within same mechanism -->
        <exclude body1="backframe_base_bottom" body2="backframe_base_top"/>
        <exclude body1="backpipe_half_L" body2="joint_base_L"/>
        <exclude body1="backpipe_half_R" body2="joint_base_R"/>
        <exclude body1="joint_base_L" body2="pulley_L"/>
        <exclude body1="joint_base_R" body2="pulley_R"/>
        <exclude body1="pulley_L" body2="leg_L"/>
        <exclude body1="pulley_R" body2="leg_R"/>
        <exclude body1="joint_base_L" body2="hip_support_L"/>
        <exclude body1="joint_base_R" body2="hip_support_R"/>
        <exclude body1="joint_base_L" body2="tsa_motor_pipe_L"/>
        <exclude body1="joint_base_R" body2="tsa_motor_pipe_R"/>
        <exclude body1="tsa_motor_pipe_L" body2="connector_L"/>
        <exclude body1="tsa_motor_pipe_R" body2="connector_R"/>

        <!-- Exclude connector from backframe (they are connected via equality) -->
        <exclude body1="backframe_base_bottom" body2="connector_L"/>
        <exclude body1="backframe_base_bottom" body2="connector_R"/>
        <exclude body1="backframe_base_bottom" body2="backpipe_half_L"/>
        <exclude body1="backframe_base_bottom" body2="backpipe_half_R"/>
    </contact>

</mujoco>
