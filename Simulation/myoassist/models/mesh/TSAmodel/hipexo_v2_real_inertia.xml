<mujoco model="hipexo_v2_real_inertia">
    <compiler angle="radian" balanceinertia="true"/>

    <option gravity="0 0 -9.81"/>

    <!-- ==================== DEFAULT CLASSES ==================== -->
    <!--
        CLASS STRUCTURE:
        ┌─────────────────────────────────────────────────────────────────────────┐
        │ GEOM CLASSES (충돌 설정) - 색상은 material로 override                   │
        ├──────────────┬──────────┬─────────────┬─────────────────────────────────┤
        │ Class        │ contype  │ conaffinity │ 적용 파트                       │
        ├──────────────┼──────────┼─────────────┼─────────────────────────────────┤
        │ collision    │ 1        │ 1           │ backframe, backpipe, joint_base │
        │              │          │             │ leg, pulley, tsa_motor_pipe     │
        │ visual       │ 0        │ 0           │ connector, hip_support          │
        └──────────────┴──────────┴─────────────┴─────────────────────────────────┘

        ┌─────────────────────────────────────────────────────────────────────────┐
        │ JOINT CLASSES (물리 속성)                                               │
        ├──────────────────┬───────────┬─────────┬───────────┬────────────────────┤
        │ Class            │ stiffness │ damping │ armature  │ 적용 조인트        │
        ├──────────────────┼───────────┼─────────┼───────────┼────────────────────┤
        │ structural_joint │ 1.0       │ 1.0     │ 0.01      │ backpipe, pipe     │
        │ active_joint     │ 0         │ 0.1     │ 0.05      │ hip, leg           │
        │ passive_joint    │ 0         │ 0.1     │ 0         │ connector, support │
        └──────────────────┴───────────┴─────────┴───────────┴────────────────────┘

        Note: 내부 충돌은 <contact><exclude>로 개별 제외됨
              색상은 material로 override (L/R 구분)
    -->
    <default>
        <!-- Exoskeleton-specific defaults wrapped in named class -->
        <default class="exo">
            <!-- Base settings for exoskeleton -->
            <joint stiffness="0" damping="0.5" armature="0.01"/>
            <geom contype="1" conaffinity="1"/>

            <!-- ===== GEOM CLASSES ===== -->
            <!-- Collision enabled (default for most parts) -->
            <default class="exo/collision">
                <geom contype="1" conaffinity="1"/>
            </default>

            <!-- Visual only - no collision (connector, hip_support) -->
            <default class="exo/visual">
                <geom contype="0" conaffinity="0"/>
            </default>

            <!-- ===== JOINT CLASSES ===== -->
            <!-- Structural joints (backpipe, pipe) - stiff connection -->
            <default class="exo/structural_joint">
                <joint stiffness="1" damping="1.0" armature="0.01" limited="true"/>
            </default>

            <!-- Active joints (hip, leg) - actuated -->
            <default class="exo/active_joint">
                <joint stiffness="0" damping="0.1" armature="0.05" limited="true"/>
            </default>

            <!-- Passive joints (connector, hip_support) - free rotation -->
            <default class="exo/passive_joint">
                <joint stiffness="0" damping="0.1" armature="0" limited="true"/>
            </default>
        </default>
    </default>

    <!-- ==================== ASSETS ==================== -->
    <asset>
        <!-- Materials for color distinction -->
        <material name="mat_backframe" rgba="0.2 0.2 0.2 1" specular="0.5" shininess="0.5"/>
        <material name="mat_backpipe" rgba="0.5 0.5 0.5 1" specular="0.3" shininess="0.2"/>
        <material name="mat_connector" rgba="0.5 0.5 0.5 1" specular="0.3" shininess="0.2"/>

        <material name="mat_joint" rgba="0.4 0.2 0.2 1" specular="0.7" shininess="0.6"/>
        <material name="mat_pulley" rgba="0.2 0.4 0.2 1" specular="0.6" shininess="0.4"/>
        <material name="mat_leg" rgba="0.2 0.2 0.4 1" specular="0.4" shininess="0.3"/>
        <material name="mat_hip_support" rgba="0.5 0.5 0.2 1" specular="0.4" shininess="0.3"/>

        <!-- Meshes -->
        <mesh name="backframe_base_bottom" file="../../TSAmesh/backframe_base_bottom.stl"/>
        <mesh name="backframe_base_top" file="../../TSAmesh/backframe_base_top.stl"/>
        <mesh name="backpipe_half" file="../../TSAmesh/backpipe_half.stl"/>
        <mesh name="connector" file="../../TSAmesh/connector.stl"/>
        <mesh name="hip_support" file="../../TSAmesh/hip_support.stl"/>
        <mesh name="joint_base" file="../../TSAmesh/joint_base.stl"/>
        <mesh name="joint_base_R" file="../../TSAmesh/joint_base_R.stl"/>
        <mesh name="leg" file="../../TSAmesh/leg.stl"/>
        <mesh name="leg_R" file="../../TSAmesh/leg_R.stl"/>
        <mesh name="pulley" file="../../TSAmesh/pulley.stl"/>
        <mesh name="pulley_R" file="../../TSAmesh/pulley_R.stl"/>
        <mesh name="tsa_motor_pipe" file="../../TSAmesh/tsa_motor_pipe.stl"/>
    </asset>

    <!-- ==================== WORLDBODY ==================== -->
    <worldbody>
        <!-- <light directional="true" pos="-0.5 0.5 3" dir="0 0 -1"/> -->
        <!-- <geom name="floor" pos="0 0 0" size="2 2 0.1" type="plane" rgba="0.9 0.85 0.7 1"/> -->

        <body name="backframe_base_bottom" pos="0 -0.16 1" euler="-0.14 0 0">
