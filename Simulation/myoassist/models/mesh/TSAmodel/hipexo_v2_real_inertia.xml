                <site name="backframe_to_shoulder_bottom_L" pos="-0.036 -0.028 0.335"/>
                <site name="backframe_to_shoulder_bottom_R" pos="0.036 -0.028 0.335"/> -->

                <site name="backframe_to_shoulder_top_L" pos="-0.046 -0.035 0.395"/>
                <site name="backframe_to_shoulder_top_R" pos="0.046 -0.035 0.395"/>


                <!-- Sites for closed loop ball joints -->
                <site name="backframe_to_connector_L" pos="-0.104 -0.04317 0.35992"/>
                <site name="backframe_to_connector_R" pos="0.104 -0.04317 0.35992"/>

            </body>

            <!-- ==================== LEFT SIDE ==================== -->
            <body name="backpipe_half_L" pos="-0.16 0.183 0.035" euler="0.16 0 0">
                <joint name="backpipe_joint_L" type="hinge" axis="1 0 0" pos="0.15 -0.22 0"
                       class="exo/structural_joint" range="-0.3 0.3"/>
                <geom name="backpipe_half_L_geom" type="mesh" mesh="backpipe_half"
                      class="exo/visual" material="mat_backpipe"/>
                <!-- backpipe_half: from real_inertia.txt (at CoM) -->
                <inertial mass="0.05548025" pos="0.03328886 -0.14909289 0"
                          fullinertia="0.00029720 0.00012446 0.00041663 -0.00012871 0 0"/>

                <body name="joint_base_L" pos="-0.034 0 -0.098" euler="0 0.119 0">
                    <joint name="pipe_joint_L" type="hinge" axis="0 -1 0" pos="0.0225 -0.022 0.101"
                           class="exo/structural_joint" range="-0.5 0.5"/>
                    <geom name="joint_base_L_geom" type="mesh" mesh="joint_base"
                          class="exo/collision" material="mat_joint"/>
                    <!-- joint_base (L): from real_inertia.txt (at CoM) -->
                    <inertial mass="0.32399464" pos="0.00261229 -0.02913209 0.02882661"
                              fullinertia="0.00088962 0.00049096 0.00043956 0.00000556 0.00002313 -0.00024432"/>

                    <!-- Pulley & Leg -->
                    <body name="pulley_L" pos="0 0 0" euler="0 0 0">
                        <joint name="hip_joint_L" type="hinge" axis="-1 0 0" pos="0 0 0"
                               class="exo/active_joint" range="-2.2 0.3"/>
                        <geom name="pulley_L_geom" type="mesh" mesh="pulley"
                              class="exo/collision" material="mat_pulley"/>
                        <!-- pulley (L): from real_inertia.txt (at CoM) -->
                        <inertial mass="0.09716543" pos="-0.00013778 -0.01038359 -0.02273681"
                                  fullinertia="0.00023246 0.00017091 0.00007127 -0.00000035 -0.00000025 -0.00001507"/>

                        <body name="leg_L" pos="0 0 -0.0665" euler="0 0 0">
                            <joint name="leg_joint_L" type="hinge" axis="0 1 0" pos="0 0 0"
                                   class="exo/active_joint" range="-0.3 1.5708"/>
                            <geom name="leg_L_geom" type="mesh" mesh="leg"
                                  class="exo/visual" material="mat_leg"/>
                            <!-- leg (L): from real_inertia.txt (at CoM) -->
                            <inertial mass="0.40720231" pos="0.01271925 -0.07381513 -0.07182682"
                                      fullinertia="0.00185795 0.00149450 0.00091057 -0.00017231 -0.00021843 0.00058454"/>


                            <geom name="leg_in_L_contact" class="exo/collision" type="cylinder" size="0.005 0.04" pos="0.103 -0.104 -0.115"/>
                            <geom name="leg_out_L_contact" class="exo/collision" type="cylinder" size="0.005 0.04" pos="0.002 -0.045 -0.115"/>


                            <!-- Sites for leg_L strap -->
                            <!-- <site name="leg_L_in_to_thigh_L_in" pos="0.1 -0.1 -0.140"/> -->
                            <!-- <site name="leg_L_out_to_thigh_L_out" pos="0.1 -0.1 -0.085"/> -->

                            <site name="leg_top_in_L" pos="0.1 -0.095 -0.09"/>
                            <site name="leg_top_out_L" pos="0.02 -0.05 -0.09"/>
                            <site name="leg_bottom_in_L" pos="0.1 -0.095 -0.13"/>
