            <inertial mass="0.57657479" pos="0 0.00694708 0.00196867"
                      fullinertia="0.00049371 0.00140837 0.00117938 0 0 -0.00001121"/>

            <site name="backframe_to_shoulder_bottom_L" pos="-0.075 0 0.037"/>
